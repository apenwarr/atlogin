// Example configuration file for atlogin.
// Copy this file to ~/.atlogin/config.json and edit as needed.
{
	// Address to listen on. Default: ":9411"
	"addr": ":9411",

	// Issuer URL for OIDC discovery. Must match what clients expect.
	"issuer": "https://at.apenwarr.ca",

	// OIDC client credentials. Map of client ID to client secret.
	// Add new clients with: atlogin -new-client <client-id>
	"secrets": {},
}
